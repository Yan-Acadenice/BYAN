{
  "name": "create-byan-agent",
  "version": "2.9.5",
  "description": "BYAN v2.8 - Intelligent AI agent creator with ELO trust system + scientific fact-check + Hermes universal dispatcher + native Claude Code integration (hooks, skills, MCP server). Multi-platform (Copilot CLI, Claude Code, Codex). Merise Agile + TDD + 64 Mantras. ~54% LLM cost savings.",
  "main": "src/index.js",
  "bin": {
    "create-byan-agent": "./install/bin/create-byan-agent-v2.js",
    "byan-v2": "./install/bin/create-byan-agent-v2.js",
    "byan-cleanup": "./install/bin/byan-cleanup.js",
    "byan-ledger": "./install/bin/byan-ledger.js",
    "byan-kanban": "./install/bin/byan-kanban.js",
    "update-byan-agent": "./update-byan-agent/bin/update-byan-agent.js"
  },
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "setup-turbo-whisper": "node install/setup-turbo-whisper.js",
    "byan": "echo \"BYAN agent installed. Use: copilot and type /agent\""
  },
  "keywords": [
    "byan",
    "ai",
    "multi-agent",
    "workflow",
    "github-copilot",
    "agent-builder",
    "bmad",
    "merise-agile",
    "tdd",
    "voice-dictation",
    "whisper",
    "turbo-whisper"
  ],
  "author": "Yan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Yan-Acadenice/BYAN.git"
  },
  "bugs": {
    "url": "https://github.com/Yan-Acadenice/BYAN/issues"
  },
  "homepage": "https://github.com/Yan-Acadenice/BYAN#readme",
  "engines": {
    "node": ">=12.0.0"
  },
  "files": [
    "src/",
    "install/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.114",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^8.2.5",
    "js-yaml": "^4.1.0",
    "ora": "^5.4.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "optionalDependencies": {
    "byan-copilot-router": "^1.0.1"
  }
}
